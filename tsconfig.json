{
    "extends": "@tsconfig/node24/tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "es2015",
        "rootDir": "./src",
        "types": ["node"],
        "resolveJsonModule": true,
        "outDir": "./dist",
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "bin/template/**", "test/**"]
}
