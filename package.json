{
    "name": "create-frontend-template",
    "version": "0.5.0",
    "packageManager": "pnpm@10.18.3",
    "scripts": {
        "install:cli": "CI=true pnpm install --filter ./packages/create-template",
        "cp:frontend-template:bin": "pnpm exec tsx scripts/copy/template/copy-frontend-template-bin.ts",
        "build:all": "pnpm exec ncc build ./packages/create-template/src/index.ts -o ./bin && pnpm exec tsx scripts/write/bin-write.ts",
        "test:react-bin": "pnpm build:all && cd test/auto && uv sync && uv run main.py react",
        "test:vue-bin": "pnpm build:all && cd test/auto && uv sync && uv run main.py vue",
        "lib:storybook": "pnpm exec turbo run storybook --filter=lib",
        "lib:test": "pnpm exec turbo run test --filter=lib",
        "story:react-tw": "pnpm exec turbo run storybook --filter=./packages/ui/react/tailwind",
        "story:react-ve": "pnpm exec turbo run storybook --filter=./packages/ui/react/vanilla-extract"
    },
    "dependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@types/adm-zip": "^0.5.7",
        "adm-zip": "^0.5.16",
        "conf": "^15.0.2",
        "csstype": "^3.2.3",
        "picocolors": "^1.1.1",
        "prettier": "^3.6.2"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/conf": "^3.0.3",
        "@types/node": "^25.0.1",
        "@vitejs/plugin-react": "^5.0.4",
        "assert": "^2.1.0",
        "browserify-zlib": "^0.2.0",
        "buffer": "^6.0.3",
        "copy-webpack-plugin": "^13.0.1",
        "process": "^0.11.10",
        "stream-browserify": "^3.0.0",
        "ts-loader": "^9.5.4",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.20.3",
        "turbo": "^2.0.0",
        "typescript": "^5.8.3"
    }
}
