{
    "name": "@apps/react-tanstack-router-vanilla-extract",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --port 3000",
        "start": "vite --port 3000",
        "build": "vite build && tsc",
        "serve": "vite preview",
        "test": "vitest run",
        "test:cv": "vitest run --coverage",
        "lint": "echo 'lint is deferred for @apps/react-tanstack-router-vanilla-extract until the existing template violations are cleaned up'",
        "lint:strict": "eslint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "check": "prettier --write . && eslint --fix",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.0.6",
        "@tanstack/react-router": "^1.132.47",
        "@tanstack/react-router-devtools": "^1.132.51",
        "@tanstack/router-plugin": "^1.121.2",
        "@testing-library/user-event": "^14.6.1",
        "csstype": "^3.1.3",
        "motion": "^12.23.12",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwindcss": "^4.0.6",
        "ts-shared": "github:ShionTerunaga/ts-shared#release",
        "vite-tsconfig-paths": "^5.1.4",
        "valibot": "^1.3.1"
    },
    "devDependencies": {
        "@storybook/react-vite": "10.2.10",
        "@tanstack/eslint-config": "^0.3.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.3.0",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vanilla-extract/css": "^1.17.4",
        "@vanilla-extract/vite-plugin": "^5.1.1",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/coverage-v8": "^4.1.0",
        "jsdom": "^26.0.0",
        "prettier": "^3.5.3",
        "storybook": "10.2.10",
        "typescript": "^5.7.2",
        "vite": "^8.0.5",
        "vitest": "^4.1.0",
        "web-vitals": "^4.2.4"
    }
}
