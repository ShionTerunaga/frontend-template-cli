{
    "name": "@apps/react-tanstack-router-tailwind",
    "version": "2.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite --port 3000",
        "build": "vite build && tsc",
        "serve": "vite preview",
        "test": "vitest run",
        "test:cv": "vitest --coverage",
        "lint": "echo 'lint is deferred for @apps/react-tanstack-router-tailwind until the existing template violations are cleaned up'",
        "lint:strict": "eslint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "check": "prettier --write . && eslint --fix",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.0.6",
        "@tanstack/react-devtools": "^0.7.0",
        "@tanstack/react-router": "^1.132.0",
        "@tanstack/react-router-devtools": "^1.132.0",
        "@tanstack/router-plugin": "^1.132.0",
        "@vitest/coverage-v8": "^4.1.0",
        "csstype": "^3.1.3",
        "lucide-react": "^0.545.0",
        "motion": "^12.23.24",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwindcss": "^4.0.6",
        "ts-shared": "github:ShionTerunaga/ts-shared#release",
        "vite-tsconfig-paths": "^5.1.4",
        "valibot": "^1.3.1"
    },
    "devDependencies": {
        "@storybook/react-vite": "10.2.10",
        "@tanstack/eslint-config": "^0.3.0",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.2.0",
        "@types/node": "^22.10.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.0.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "jsdom": "^27.0.0",
        "prettier": "^3.5.3",
        "storybook": "10.2.10",
        "typescript": "^5.7.2",
        "vite": "^8.0.5",
        "vitest": "^4.1.0",
        "web-vitals": "^5.1.0"
    }
}
